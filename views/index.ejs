<body>
  <div class="main-wrapper">

    <!-- 🔵 Left Panel: User List -->
    <div class="user-list">
      <h3>Contacts</h3>
      <input type="text" placeholder="Search User" />
      <div id="online-users">
        <!-- Users will be injected here dynamically -->
      </div>
    </div>

    <!-- 🟣 Center Panel: Chat Window -->
    <div class="chat-section">
      <!-- Welcome Screen -->
      <header class="chat-welcome" id="chat-welcome">
        <h1>QuickChat</h1>
        <p class="slogan">Connect instantly. Chat privately.</p>
      </header>

      <!-- Active Chat Screen -->
      <div class="chat-active">
        <div id="chat-header" class="chat-header">
          
          <!-- This will be replaced with selected user's name -->
        </div>

        <main class="chat-messages" id="messages">
          <!-- Messages will appear here -->
        </main>

        <form id="form" class="chat-form">

<!-- yaha se delete karna hai-->
          <!-- WhatsApp style plus button -->
          <label for="mediaInput" class="upload-btn">
            <i class="fas fa-plus"></i>
          </label>

          <!-- hidden file input -->
          <input type="file" id="mediaInput" hidden>
<!-- yaha takk delete karna hai-->
          <input id="input" autocomplete="off" placeholder="Send a message..." />
          <button><i class="fas fa-paper-plane"></i></button>
        </form>
        </form>
      </div>
    </div>

    <!-- 🟢 Right Panel: Profile Info -->
    <div class="profile-section" id="profile-box">
      <h3>Profile</h3>
      <img src="/images/logo.png" alt="Profile" style="width:100px; border-radius:50%;">
      <p><strong>
          <%= username %>
        </strong></p>
      <p>Status: Online</p>
      <button onclick="window.location='/logout'">Logout</button>
    </div>

    <!-- ✅ Hidden Inputs for JS -->
    <input type="hidden" id="myUserId" value="<%= userId %>">
    <input type="hidden" id="myUsername" value="<%= username %>">

  </div>

  <script>

  const mediaInput = document.getElementById("mediaInput");

  mediaInput.addEventListener("change", async function () {

    const file = mediaInput.files[0];
    if (!file) return;

    const formData = new FormData();
    formData.append("media", file);

    const res = await fetch("/upload", {
      method: "POST",
      body: formData
    });

    const data = await res.json();

    if (data.filePath) {
      document.getElementById("input").value = data.filePath;
    }
  });
  </script>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/client.js"></script>

